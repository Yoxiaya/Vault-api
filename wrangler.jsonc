			"database_id": "15eee015-65c8-4375-897a-3c8ee2b5fc9e",
			"remote": true,
		},
	],
	"dev": {
		"ip": "0.0.0.0",
		"port": 8787,
	},
	"vars": {
		"IMAGE_API_URL": "https://api.superbed.cn",
	},
}
