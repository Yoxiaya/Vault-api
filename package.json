{
  "name": "vault-api",
  "type": "module",
  "scripts": {
    "dev": "bash start.sh",
    "dev:local": "bash start.sh -m local",
    "dev:port": "bash start.sh -p",
    "sync": "bash ./script/syncDbData.sh",
    "deploy": "wrangler deploy --minify",
    "build": "echo 'Build completed'",
    "format": "prettier --write \"src/**/*.ts\"",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260610.1",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "3.8.3",
    "wrangler": "^4.4.0"
  }
}
